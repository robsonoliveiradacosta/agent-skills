#!/bin/sh
# Global commit-msg guard: strip AI attribution from commit messages.
# Runs on every `git commit` in any repo that uses the global core.hooksPath.
# Removes Claude/Anthropic co-author trailers and "Generated with Claude Code"
# footers, regardless of who (model, skill, or human) wrote the message.
#
# Installed by setup-git-hooks.sh. Source of truth lives in this repo.

msg_file="$1"

sed -i \
  -e '/^[Cc]o-[Aa]uthored-[Bb]y:.*[Cc]laude/d' \
  -e '/noreply@anthropic\.com/d' \
  -e '/Generated with \[Claude Code\]/d' \
  -e '/🤖 Generated with/d' \
  "$msg_file"

# Drop blank lines left dangling at the end of the message.
sed -i -e :a -e '/^\n*$/{$d;N;ba}' "$msg_file" 2>/dev/null || true

# Don't disable an existing per-repo hook: the global core.hooksPath would
# otherwise bypass .git/hooks/commit-msg. Resolve the repo's real hooks dir
# (independent of core.hooksPath) and delegate if a hook lives there.
git_dir="$(git rev-parse --git-dir 2>/dev/null)" || git_dir=""
if [ -n "$git_dir" ]; then
  local_hook="$git_dir/hooks/commit-msg"
  if [ -x "$local_hook" ] && [ "$local_hook" != "$0" ]; then
    exec "$local_hook" "$@"
  fi
fi

exit 0
